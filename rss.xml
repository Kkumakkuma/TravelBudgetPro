---
layout: null
permalink: /rss.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/" xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <description>{{ site.description | xml_escape }}</description>
    <link>{{ site.url }}{{ site.baseurl }}/</link>
    <atom:link href="{{ site.url }}{{ site.baseurl }}/rss.xml" rel="self" type="application/rss+xml" />
    <language>en</language>
    <lastBuildDate>{{ site.time | date_to_rfc822 }}</lastBuildDate>
    {% for post in site.posts limit:30 %}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <description><![CDATA[{{ post.description | default: post.excerpt | strip_html | truncate: 500 }}]]></description>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <link>{{ post.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
      {% assign first_image = "" %}
      {% if post.content contains "<img" %}
        {% assign img_parts = post.content | split: "<img" %}
        {% if img_parts.size > 1 %}
          {% assign cand = img_parts[1] | split: 'src="' | last | split: '"' | first %}
          {% if cand != post.content %}
            {% assign first_image = cand %}
          {% endif %}
        {% endif %}
      {% endif %}
      {% if first_image == "" and post.content contains "![" %}
        {% assign md_parts = post.content | split: "![" %}
        {% if md_parts.size > 1 %}
          {% assign cand = md_parts[1] | split: "](" | last | split: ")" | first %}
          {% if cand != post.content %}
            {% assign first_image = cand %}
          {% endif %}
        {% endif %}
      {% endif %}
      {% if first_image != "" %}
        {% if first_image contains "http" %}
      <enclosure url="{{ first_image }}" type="image/png" />
      <media:content url="{{ first_image }}" medium="image" />
        {% elsif first_image contains "/assets/" %}
          {% assign full_url = site.url | append: first_image %}
      <enclosure url="{{ full_url }}" type="image/png" />
      <media:content url="{{ full_url }}" medium="image" />
        {% endif %}
      {% endif %}
    </item>
    {% endfor %}
  </channel>
</rss>
